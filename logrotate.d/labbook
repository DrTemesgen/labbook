# Dedicated rotation for Alembic migration log
# /storage has permissive permissions, so we use "su" to satisfy logrotate security checks
/storage/log/alembic.out {
    weekly
    rotate 180
    compress
    copytruncate
    missingok
    notifempty
    dateext
    su root root
}

